# Alle Keys optional — ohne sie läuft die App über kostenlose Quellen (CNBC/Nasdaq).
# Für Docker: diese Datei nach .env kopieren (leere Werte sind ok): cp .env.example .env

# RapidAPI (Yahoo Finance): stabilere Kurse + Analystenziele/PEG/Cashflow. ./setkey.sh hilft.
YH_RAPIDAPI_KEY=
YH_RAPIDAPI_HOST=yahoo-finance-real-time1.p.rapidapi.com

# Financial Modeling Prep: US-Fundamentals. Gratisplan deckt nur wenige Symbole ab.
FMP_API_KEY=

# Telegram-Agent (optional). Siehe ./telegram-setup.sh
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
